CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r2s=y

# Base system
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_openssh-sftp-server=y

# Ethernet drivers
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-r8152=y

# Disable IPv6
CONFIG_IPV6=n
CONFIG_KERNEL_IPV6=n
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=n
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_ip6tables=n
CONFIG_PACKAGE_kmod-ip6tables=n
CONFIG_PACKAGE_kmod-ipv6=n
CONFIG_PACKAGE_kmod-nf-conntrack6=n
CONFIG_PACKAGE_kmod-nf-nat6=n
CONFIG_PACKAGE_kmod-nf-reject6=n
CONFIG_PACKAGE_kmod-icmpv6=n
CONFIG_PACKAGE_kmod-sit=n
CONFIG_PACKAGE_luci-proto-ipv6=n
CONFIG_PACKAGE_odhcp6c=n
CONFIG_PACKAGE_rpcd-mod-rrdns=n
